# Copy this file to .env and fill in real values from your Supabase project.
# Never commit the real .env file - .gitignore below already excludes it.

# Supabase: Project Settings -> Database -> Connection string
# "Transaction pooler" connection (port 6543) - used by the running app, supports many short-lived connections
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# "Session pooler" or "Direct connection" (port 5432) - used only when running migrations
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"
